{
  "name": "lorecraft",
  "version": "0.1.0",
  "description": "CLI/TUI agent for long-form novel writing.",
  "type": "module",
  "bin": {
    "lorecraft": "./dist/main.js"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
